platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting Flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. Run flutter pub get before pod install."
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Delete Generated.xcconfig, then run flutter pub get."
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

def patch_runner_embed_frameworks_phase
  runner_project_path = File.join(__dir__, 'Runner.xcodeproj')
  runner_project = Xcodeproj::Project.open(runner_project_path)
  runner_target = runner_project.targets.find { |target| target.name == 'Runner' }
  embed_phase = runner_target&.shell_script_build_phases&.find do |phase|
    phase.name == '[CP] Embed Pods Frameworks'
  end

  return unless embed_phase

  embed_phase.input_file_list_paths = []
  embed_phase.output_file_list_paths = []
  embed_phase.input_paths = [
    '${BUILT_PRODUCTS_DIR}/sign_in_with_apple/sign_in_with_apple.framework',
  ]
  embed_phase.output_paths = [
    '${TARGET_BUILD_DIR}/${FRAMEWORKS_FOLDER_PATH}/sign_in_with_apple.framework',
  ]
  embed_phase.shell_script = <<~SCRIPT
    set -e
    if [ -z ${FRAMEWORKS_FOLDER_PATH+x} ]; then
      exit 0
    fi
    SOURCE="${BUILT_PRODUCTS_DIR}/sign_in_with_apple/sign_in_with_apple.framework"
    DESTINATION="${TARGET_BUILD_DIR}/${FRAMEWORKS_FOLDER_PATH}"
    mkdir -p "${DESTINATION}"
    if [ -d "${SOURCE}" ]; then
      rsync --delete -avL --filter "- CVS/" --filter "- .svn/" --filter "- .git/" --filter "- .hg/" --filter "- Headers" --filter "- PrivateHeaders" --filter "- Modules" "${SOURCE}" "${DESTINATION}"
      FRAMEWORK="${DESTINATION}/sign_in_with_apple.framework"
      BINARY="${FRAMEWORK}/sign_in_with_apple"
      if [ -r "${BINARY}" ] && lipo -info "${BINARY}" | grep -q x86_64 && [[ "${ARCHS}" != *"x86_64"* ]]; then
        lipo -remove x86_64 -output "${BINARY}" "${BINARY}"
      fi
      if [ -d "${FRAMEWORK}" ] && [ "${CODE_SIGNING_ALLOWED:-NO}" != "NO" ] && [ -n "${EXPANDED_CODE_SIGN_IDENTITY:-}" ]; then
        codesign --force --sign "${EXPANDED_CODE_SIGN_IDENTITY}" --preserve-metadata=identifier,entitlements,flags "${FRAMEWORK}"
      fi
    else
      echo "warning: sign_in_with_apple.framework was not found at ${SOURCE}"
    fi
  SCRIPT
  runner_project.save
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end
end

post_integrate do |_installer|
  patch_runner_embed_frameworks_phase
end
